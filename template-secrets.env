# Secrets the gateway loads from environment. These are PROVISIONED at deploy
# time (Secrets Manager → /opt/arcnode/secrets.env → env_file in compose);
# this file is the LIST of names, NOT the values. Never commit values.

# Broker auth (platform's File-RBAC HiveMQ). Username is config
# (cfg.defaults.yml `mqtt_username: arcnode_gateway`); password is the secret.
MQTT_GATEWAY_PASSWORD=

# SNMPv3 USM passphrases — keyed by security_name (uppercase, '-' → '_').
# Required when a device's x-device-trust uses `snmpv3_usm`.
SNMP_USM_GATEWAY_AUTH_PASSPHRASE=
SNMP_USM_GATEWAY_PRIV_PASSPHRASE=
